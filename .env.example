# Security
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=*

# PostgreSQL — للتطوير المحلي العادي
DATABASE_URL=postgresql://postgres:your_password_here@localhost:5432/care4child_db

# PostgreSQL — داخل Docker (استخدم هذا في .env.docker)
# DATABASE_URL=postgresql://postgres:your_password_here@db:5432/care4child_db

# CORS — اضبطه على False في الإنتاج وأضف النطاقات المسموح بها
CORS_ALLOW_ALL=True
# CORS_ALLOWED_ORIGINS=https://yourapp.com,https://yourapp2.com
